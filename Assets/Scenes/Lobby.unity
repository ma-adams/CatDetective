--- !u!114 &1995693084
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1995693079}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 0e09f156ea27649c8a89ed219d2e6635, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueTrigger
  dialogue:
    sentences:
    - '*Sigh*'
    - 'Huh? Oh sorry, didn''t see you there. I''m not super focused today.  '
    - I lost my bracelet this morning. It's been in my family for generations!
    - Say, you're not busy right? Could you help me find my bracelet pleaseeeee?
    - 'Oh, thank you!  '
    startQuestId: music_quest
    completeQuestId: 
    requiredItem: 
    fallbackDialogue: 
  questDialogue:
    sentences:
    - I don't know how I'll tell Grammie I lost the family bracelet!
    startQuestId: 
    completeQuestId: 
    requiredItem: 
    fallbackDialogue: 
  rewardDialogue:
    sentences:
    - Oh THANK YOU!! You really saved my tail!
    - I don't have any money for you but I can tell you this...
    - 'I''ve worked here for a long time. I was here when the orignal murder happened.
      The killer was never found... '
    - 'The staff live at the other end of the hall, away from Fluffy, but last night
      I was woken up by yelling coming from Fluffy''s side of the hall. Funnily,
      Bar Cat was nowhere to be found. '
    startQuestId: 
    completeQuestId: music_quest
    requiredItem: 
    fallbackDialogue: 
  completedDialogue:
    sentences:
    - Thanks again for finding my bracelet!
    startQuestId: 
    completeQuestId: 
    requiredItem: 
    fallbackDialogue: 
  requiredItem: SM_bracelet
  requiredItems: []
  questId: music_quest
