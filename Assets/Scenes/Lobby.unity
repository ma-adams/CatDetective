  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueTrigger
  dialogue:
    sentences:
    - Hey there! Welcome to the Cat Nap!
    - 'Sorry for the wait, we''re shortstaffed. '
    - Heck, I'm doing like three cats-worth of work!
    - I'm in over my head. Could you help me clean up the lobby?
    startQuestId: bellhop_quest
    completeQuestId: 
    requiredItem: 
    fallbackDialogue: 
  questDialogue:
    sentences:
    - The sooner I get this place cleaned up, the sooner I get your room ready...
    startQuestId: 
    completeQuestId: 
    requiredItem: 
    fallbackDialogue: 
  rewardDialogue:
    sentences:
    - Thank you so much!! I feel so relieved!
    - 'Hey, just so you know, since you''re a detective, Fluffy was real interested
      in the laundry chute. '
    - I don't know, maybe his next story was about hotel laundry practices?
    - 'I didn''t see anything last night either. My room is in the basement. '
    - 'Mr. Curio did wake me up to turn the power back on though. '
    startQuestId: 
    completeQuestId: bellhop_quest
    requiredItem: 
    fallbackDialogue: 
  completedDialogue:
    sentences:
    - I'll get started on your room right away!
    startQuestId: 
    completeQuestId: 
    requiredItem: 
    fallbackDialogue: 
